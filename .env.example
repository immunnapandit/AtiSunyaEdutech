NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Same Google OAuth Client ID as backend/.env GOOGLE_CLIENT_ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Same Microsoft app as backend/.env MICROSOFT_CLIENT_ID / MICROSOFT_TENANT_ID
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-application-client-id
NEXT_PUBLIC_MICROSOFT_TENANT_ID=common

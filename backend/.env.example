PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
JWT_SECRET=change-this-secret-before-production
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id
GRAPH_CLIENT_SECRET=your-client-secret
GRAPH_FROM_EMAIL=sender@your-domain.com
ADMIN_NOTIFICATION_EMAIL=admin@your-domain.com
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Google Sign-In (Google Cloud Console > APIs & Services > Credentials > OAuth Client ID > Web application)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Microsoft Sign-In (Azure Portal > App registrations > your app > Application (client) ID)
MICROSOFT_CLIENT_ID=your-microsoft-application-client-id
# Use "common" for multi-tenant/personal accounts, or your tenant ID/domain to restrict to one org
MICROSOFT_TENANT_ID=common

# MongoDB Atlas connection string (required in production; empty = local dev database)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/atisunya?retryWrites=true&w=majority

# Admin CMS credentials (required for /admin panel login)
ADMIN_PANEL_EMAIL=admin@your-domain.com
ADMIN_PANEL_PASSWORD=choose-a-strong-password

# Cloudinary (dashboard > Settings > API Keys)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Supported aliases if you already named them this way:
# TENANT_ID=your-tenant-id
# CLIENT_ID=your-client-id
# CLIENT_SECRET=your-client-secret
# EMAIL=sender@your-domain.com
